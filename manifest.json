{
  "manifest_version": 3,
  "name": "小红书一键搜索",
  "version": "2.7.0",
  "description": "选中文字搜索小红书，支持分屏/悬浮小窗，搜索结果页可 AI 总结趋势",
  "permissions": ["contextMenus", "storage", "windows"],
  "host_permissions": [
    "https://cowork.xiaohongshu.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_start",
      "all_frames": true
    },
    {
      "matches": ["*://*.xiaohongshu.com/search_result*"],
      "js": ["trend.js"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_title": "小红书一键搜索",
    "default_popup": "popup.html"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
